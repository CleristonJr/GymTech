// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Gym {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   // SUPER_ADMIN, GYM_ADMIN, TRAINER, STUDENT
  gymId     String?
  gym       Gym?     @relation(fields: [gymId], references: [id])
  
  // Gamificação
  points    Int      @default(0)
  streak    Int      @default(0)
  crystals  Int      @default(3)
  shortId   String?  @unique

  mustChangePassword Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerPlans WorkoutPlan[]    @relation("TrainerPlans")
  studentPlans WorkoutPlan[]    @relation("StudentPlans")
  sessions     WorkoutSession[]
  measurements Measurement[]
  
  // Grupos
  ownedGroups  Group[]          @relation("GroupOwner")
  groupMembers GroupMember[]
}

model Measurement {
  id          String   @id @default(cuid())
  studentId   String
  weight      Float
  bodyFat     Float?
  note        String?
  createdAt   DateTime @default(now())
  student     User     @relation(fields: [studentId], references: [id])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  
  members   GroupMember[]
  createdAt DateTime @default(now())
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  
  group     Group    @relation(fields: [groupId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
}

model Exercise {
  id          String   @id @default(cuid())
  name        String
  description String?
  gifUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  name      String
  trainerId String
  studentId String
  trainer   User     @relation("TrainerPlans", fields: [trainerId], references: [id])
  student   User     @relation("StudentPlans", fields: [studentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises WorkoutExercise[]
  sessions  WorkoutSession[]
}

model WorkoutExercise {
  id            String      @id @default(cuid())
  workoutPlanId String
  exerciseId    String
  sets          Int
  reps          Int
  restTimeSecs  Int         @default(60)
  orderIndex    Int         @default(0)
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])
}

model WorkoutSession {
  id            String      @id @default(cuid())
  workoutPlanId String
  studentId     String
  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
  status        String      @default("STARTED") // STARTED, COMPLETED
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  student       User        @relation(fields: [studentId], references: [id])
}
